<UserControl x:Class="SistemaInventarioCompuElectric1.COTIZACION.CotizacionItemControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             mc:Ignorable="d" 
             d:DesignHeight="120" d:DesignWidth="550">

    <Border BorderBrush="LightGray" BorderThickness="0,0,0,1" Padding="10">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100"/>
                <!-- Imagen más grande -->
                <ColumnDefinition Width="*"/>
                <!-- Información -->
                <ColumnDefinition Width="130"/>
                <!-- Cantidad -->
                <ColumnDefinition Width="130"/>
                <!-- Subtotal -->
                <ColumnDefinition Width="40"/>
                <!-- Eliminar -->
            </Grid.ColumnDefinitions>

            <!-- IMAGEN DEL PRODUCTO MÁS GRANDE Y VISIBLE -->
            <Border Grid.Column="0" Width="90" Height="90" 
                    BorderBrush="LightGray" BorderThickness="1" 
                    CornerRadius="8" Margin="0,0,10,0"
                    Background="White"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <Grid>
                    <Image x:Name="imgProducto" 
                           Stretch="Uniform" 
                           StretchDirection="Both"
                           Loaded="Imagen_Loaded"
                           Unloaded="Imagen_Unloaded"
                           Margin="5"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
                    <TextBlock x:Name="txtSinImagen" 
                               Text="Sin imagen" 
                               HorizontalAlignment="Center" 
                               VerticalAlignment="Center"
                               FontSize="10"
                               Foreground="Gray"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               Visibility="Collapsed"/>
                    <Border BorderBrush="LightGray" BorderThickness="1" 
                            CornerRadius="8" Opacity="0.3" IsHitTestVisible="False"/>
                </Grid>
            </Border>

            <!-- Nombre y código (con más espacio) -->
            <StackPanel Grid.Column="1" Margin="10,0" VerticalAlignment="Center">
                <TextBlock x:Name="txtNombre" Text="Nombre del producto" 
                           FontSize="15" FontWeight="SemiBold"
                           TextTrimming="CharacterEllipsis"/>
                <TextBlock x:Name="txtCodigo" Text="Código" 
                           FontSize="11" Foreground="Gray"/>
            </StackPanel>

            <!-- Cantidad con control (más grande) -->
            <Grid Grid.Column="2" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="35"/>
                    <ColumnDefinition Width="40"/>
                    <ColumnDefinition Width="35"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" x:Name="btnMenos" 
                        Width="35" Height="35" Padding="0"
                        Background="Transparent" BorderThickness="0"
                        Click="BtnMenos_Click"
                        Cursor="Hand">
                    <iconPacks:PackIconMaterial Kind="MinusCircle" 
                                                Width="26" Height="26" Foreground="Red"/>
                </Button>

                <TextBlock Grid.Column="1" x:Name="txtCantidad" Text="1" 
                           FontSize="16" FontWeight="Bold"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>

                <Button Grid.Column="2" x:Name="btnMas" 
                        Width="35" Height="35" Padding="0"
                        Background="Transparent" BorderThickness="0"
                        Click="BtnMas_Click"
                        Cursor="Hand">
                    <iconPacks:PackIconMaterial Kind="PlusCircle" 
                                                Width="26" Height="26" Foreground="Green"/>
                </Button>
            </Grid>

            <!-- Subtotal (más grande) -->
            <TextBlock Grid.Column="3" x:Name="txtSubtotal" Text="S/ 0.00" 
                       FontSize="16" FontWeight="Bold" Foreground="#143c5b"
                       HorizontalAlignment="Right" VerticalAlignment="Center"
                       Margin="0,0,15,0"/>

            <!-- Botón eliminar (más grande) -->
            <Button Grid.Column="4" x:Name="btnEliminar" 
                    Width="35" Height="35" Padding="0"
                    Background="Transparent" BorderThickness="0"
                    Click="BtnEliminar_Click"
                    Cursor="Hand"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <iconPacks:PackIconMaterial Kind="Delete" 
                                            Width="26" Height="26" Foreground="Red"/>
            </Button>
        </Grid>
    </Border>
</UserControl>