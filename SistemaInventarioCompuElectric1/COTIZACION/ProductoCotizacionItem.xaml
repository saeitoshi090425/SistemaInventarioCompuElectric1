<UserControl x:Class="SistemaInventarioCompuElectric1.COTIZACION.ProductoCotizacionItem"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             mc:Ignorable="d" 
             d:DesignHeight="120" d:DesignWidth="850"
             MouseLeftButtonDown="UserControl_MouseLeftButtonDown"
             Cursor="Hand">

    <Border BorderBrush="LightGray" BorderThickness="0,0,0,1" Padding="10">
        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="Background" Value="Transparent"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#F0F8FF"/>
                    </Trigger>
                </Style.Triggers>
            </Style>
        </Border.Style>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120"/>
                <!-- Imagen más grande -->
                <ColumnDefinition Width="60"/>
                <!-- Cantidad -->
                <ColumnDefinition Width="*"/>
                <!-- Información -->
                <ColumnDefinition Width="120"/>
                <!-- Categoría -->
                <ColumnDefinition Width="120"/>
                <!-- Precio -->
                <ColumnDefinition Width="40"/>
                <!-- Icono -->
            </Grid.ColumnDefinitions>

            <!-- IMAGEN DEL PRODUCTO MÁS GRANDE -->
            <Border Grid.Column="0" Width="110" Height="110" 
                    BorderBrush="LightGray" BorderThickness="1" 
                    CornerRadius="8" Margin="0,0,10,0"
                    Background="White"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <Grid>
                    <Image x:Name="imgProducto" 
                           Stretch="Uniform" 
                           StretchDirection="Both"
                           Loaded="Imagen_Loaded"
                           Unloaded="Imagen_Unloaded"
                           Margin="5"/>
                    <TextBlock x:Name="txtSinImagen" 
                               Text="Sin imagen" 
                               HorizontalAlignment="Center" 
                               VerticalAlignment="Center"
                               FontSize="11"
                               Foreground="Gray"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               Visibility="Collapsed"/>
                </Grid>
            </Border>

            <!-- Cantidad disponible (más grande) -->
            <Border Grid.Column="1" Background="#143c5b" CornerRadius="18" 
                    Width="36" Height="36" HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock x:Name="txtCantidadDisponible" Text="0" 
                           Foreground="White" FontWeight="Bold" 
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           FontSize="14"/>
            </Border>

            <!-- Información del producto (con más espacio) -->
            <StackPanel Grid.Column="2" Margin="10,0" VerticalAlignment="Center">
                <TextBlock x:Name="txtNombre" Text="Nombre del producto" 
                           FontSize="16" FontWeight="SemiBold"
                           TextTrimming="CharacterEllipsis"/>
                <TextBlock x:Name="txtCodigo" Text="Código" 
                           FontSize="12" Foreground="Gray"/>
            </StackPanel>

            <!-- Categoría (más legible) -->
            <Border Grid.Column="3" Background="#143c5b" CornerRadius="20" 
                    Height="36" Width="100" HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock x:Name="txtCategoria" Text="Categoría" 
                           Foreground="White" FontSize="12" FontWeight="Bold"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>

            <!-- Precio (más grande) -->
            <TextBlock Grid.Column="4" x:Name="txtPrecio" Text="S/ 0.00" 
                       FontSize="18" FontWeight="Bold" Foreground="#143c5b"
                       VerticalAlignment="Center" HorizontalAlignment="Right"
                       Margin="0,0,10,0"/>

            <!-- Icono de agregar (más grande) -->
            <iconPacks:PackIconMaterial Grid.Column="5" Kind="PlusCircle" 
                                        Width="32" Height="32" Foreground="Green"
                                        VerticalAlignment="Center" HorizontalAlignment="Center"/>
        </Grid>
    </Border>
</UserControl>