<UserControl x:Class="SistemaInventarioCompuElectric1.INVENTARIO.ProductoItemControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             mc:Ignorable="d" 
             d:DesignHeight="120" d:DesignWidth="900">
    <Border BorderBrush="LightGray" BorderThickness="0,0,0,1" Padding="5">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="400"/>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="300"/>
                <!-- AUMENTADO: antes era 250 -->
                <ColumnDefinition Width="160"/>
            </Grid.ColumnDefinitions>

            <!-- NOMBRE -->
            <TextBlock Grid.Column="0" Text="{Binding nombre}" 
                       VerticalAlignment="Center" FontSize="14" Margin="5,0"
                       TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"
                       FontWeight="Medium"/>

            <!-- CÓDIGO -->
            <TextBlock Grid.Column="1" Text="{Binding codigo}" 
                       VerticalAlignment="Center" FontSize="14" Margin="5,0"/>

            <!-- CATEGORÍA -->
            <Border Grid.Column="2" Background="#143c5b" CornerRadius="15" 
                    Height="25" Width="80" Margin="5,0">
                <TextBlock Text="{Binding categoria}" 
                           VerticalAlignment="Center" 
                           HorizontalAlignment="Center"
                           FontSize="11" 
                           Foreground="White"
                           FontWeight="Bold"/>
            </Border>

            <!-- CANTIDAD -->
            <TextBlock Grid.Column="3" Text="{Binding cantidad}" 
                       VerticalAlignment="Center" FontSize="14" Margin="5,0"/>

            <!-- PRECIO -->
            <TextBlock Grid.Column="4" Text="{Binding precio, StringFormat='S/ {0:F2}'}" 
                       VerticalAlignment="Center" FontSize="14" Margin="5,0"
                       FontWeight="Bold" Foreground="#143c5b"/>

            <!-- ESTANTE -->
            <TextBlock Grid.Column="5" Text="{Binding estante}" 
                       VerticalAlignment="Center" FontSize="14" Margin="5,0"/>

            <!-- FILA -->
            <TextBlock Grid.Column="6" Text="{Binding fila}" 
                       VerticalAlignment="Center" FontSize="14" Margin="5,0"/>

         
            <Border Grid.Column="7" Width="160" Height="100" BorderBrush="Gray" 
                BorderThickness="1" CornerRadius="5" Margin="5"
                    Background="White">
                <Grid>
                    <Image x:Name="imgProducto" Stretch="Uniform" 
                           Loaded="Imagen_Loaded"
                           Unloaded="Imagen_Unloaded"
                           Margin="2"/>
                    <TextBlock x:Name="txtSinImagen" 
                               Text="Sin imagen" 
                               HorizontalAlignment="Center" 
                               VerticalAlignment="Center"
                               FontSize="11"
                               Foreground="Gray"
                               Visibility="Collapsed"/>
                </Grid>
            </Border>

            <StackPanel Grid.Column="8" Orientation="Horizontal" HorizontalAlignment="Center" 
                        VerticalAlignment="Center">
                <Button Cursor="Hand" Width="32" Height="32" Margin="5" 
                        ToolTip="Editar" Click="Editar_Click"
                        Background="Transparent" BorderThickness="0">
                    <iconPacks:PackIconMaterial Kind="Pencil" Width="18" Height="18" Foreground="#143c5b"/>
                </Button>
                <Button Cursor="Hand" Width="32" Height="32" Margin="5" 
                        ToolTip="Eliminar" Click="Eliminar_Click"
                        Background="Transparent" BorderThickness="0">
                    <iconPacks:PackIconMaterial Kind="Delete" Width="18" Height="18" Foreground="Red"/>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>