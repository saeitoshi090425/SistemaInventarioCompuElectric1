
<UserControl x:Class="SistemaInventarioCompuElectric1.INVENTARIO.ProductoItemControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             mc:Ignorable="d"
             d:DesignHeight="80" d:DesignWidth="800">
	<Border BorderBrush="LightGray" BorderThickness="0,0,0,1" Padding="5">
		<Grid>
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="500"/>
				<ColumnDefinition Width="190"/>
				<ColumnDefinition Width="150"/>
				<ColumnDefinition Width="150"/>
				<ColumnDefinition Width="100"/>
				<ColumnDefinition Width="100"/>
				<ColumnDefinition Width="200"/>
				<ColumnDefinition Width="160"/>
			</Grid.ColumnDefinitions>

			<TextBlock x:Name="txtNombre" Grid.Column="0" Text="{Binding Nombre}"
                       VerticalAlignment="Center" FontSize="14" Margin="5,0"/>

			<TextBlock x:Name="txtCodigo" Grid.Column="1" Text="{Binding Codigo}"
                       VerticalAlignment="Center" FontSize="14" Margin="5,0"/>

			<TextBlock x:Name="txtCantidad" Grid.Column="2" Text="{Binding Cantidad}"
                       VerticalAlignment="Center" FontSize="14" Margin="5,0"/>

			<TextBlock x:Name="txtPrecio" Grid.Column="3" Text="{Binding Precio, StringFormat=C}"
                       VerticalAlignment="Center" FontSize="14" Margin="5,0"/>

			<TextBlock x:Name="txtEstante" Grid.Column="4" Text="{Binding Estante}"
                       VerticalAlignment="Center" FontSize="14" Margin="5,0"/>

			<TextBlock x:Name="txtFila" Grid.Column="5" Text="{Binding Fila}"
                       VerticalAlignment="Center" FontSize="14" Margin="5,0"/>

			<Border Grid.Column="6" Width="80" Height="60" BorderBrush="Gray"
                    BorderThickness="1" CornerRadius="3" Margin="5">
				<Image x:Name="imgProducto" Stretch="UniformToFill"
                       Source="{Binding ImagenUrl, Converter={StaticResource UrlToImageConverter}}"/>
			</Border>

			<StackPanel Grid.Column="7" Orientation="Horizontal" HorizontalAlignment="Center"
                        VerticalAlignment="Center">
				<Button Cursor="Hand" Width="32" Height="32" Margin="5"
                        ToolTip="Editar" Click="Editar_Click">
					<iconPacks:PackIconMaterial Kind="Pencil" Width="16" Height="16"/>
				</Button>
				<Button Cursor="Hand" Width="32" Height="32" Margin="5"
                        ToolTip="Eliminar" Click="Eliminar_Click">
					<iconPacks:PackIconMaterial Kind="Delete" Width="16" Height="16" Foreground="Red"/>
				</Button>
			</StackPanel>
		</Grid>
	</Border>
</UserControl>