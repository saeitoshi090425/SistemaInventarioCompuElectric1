<Window x:Class="SistemaInventarioCompuElectric1.INVENTARIO.EditarProductoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        Title="Editar Producto" Height="650" Width="500"
        WindowStartupLocation="CenterScreen"
        Background="White"
        WindowStyle="SingleBorderWindow"
        ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- TÍTULO -->
        <TextBlock Grid.Row="0" Text="EDITAR PRODUCTO" 
                   FontSize="24" FontWeight="Bold" 
                   Foreground="#143c5b" 
                   HorizontalAlignment="Center"
                   Margin="0,0,0,20"/>

        <!-- ID (oculto) -->
        <TextBox x:Name="txtId" Grid.Row="1" Visibility="Collapsed"/>

        <!-- NOMBRE -->
        <TextBlock Grid.Row="1" Text="Nombre del Producto:" 
                   FontSize="14" FontWeight="SemiBold" 
                   Foreground="#143c5b" Margin="0,5"/>
        <TextBox x:Name="txtNombre" Grid.Row="2" 
                 Height="40" Padding="10" 
                 FontSize="14" 
                 BorderBrush="#143c5b" BorderThickness="1"
                 Margin="0,0,0,10"/>

        <!-- CÓDIGO -->
        <TextBlock Grid.Row="3" Text="Código:" 
                   FontSize="14" FontWeight="SemiBold" 
                   Foreground="#143c5b" Margin="0,5"/>
        <TextBox x:Name="txtCodigo" Grid.Row="4" 
                 Height="40" Padding="10" 
                 FontSize="14" 
                 BorderBrush="#143c5b" BorderThickness="1"
                 Margin="0,0,0,10"/>

        <!-- CATEGORÍA -->
        <TextBlock Grid.Row="5" Text="Categoría:" 
                   FontSize="14" FontWeight="SemiBold" 
                   Foreground="#143c5b" Margin="0,5"/>
        <ComboBox x:Name="cmbCategoria" Grid.Row="6" 
                  Height="40" Padding="10" 
                  FontSize="14" 
                  BorderBrush="#143c5b" BorderThickness="1"
                  IsEnabled="False" Margin="0,0,0,10">
            <ComboBoxItem Content="Electrónica"/>
            <ComboBoxItem Content="Robótica"/>
            <ComboBoxItem Content="Accesorios"/>
        </ComboBox>

        <!-- CANTIDAD Y PRECIO EN GRID -->
        <Grid Grid.Row="7" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- CANTIDAD -->
            <StackPanel Grid.Column="0">
                <TextBlock Text="Cantidad:" 
                           FontSize="14" FontWeight="SemiBold" 
                           Foreground="#143c5b" Margin="0,5"/>
                <TextBox x:Name="txtCantidad" 
                         Height="40" Padding="10" 
                         FontSize="14" 
                         BorderBrush="#143c5b" BorderThickness="1"/>
            </StackPanel>

            <!-- PRECIO -->
            <StackPanel Grid.Column="2">
                <TextBlock Text="Precio (S/):" 
                           FontSize="14" FontWeight="SemiBold" 
                           Foreground="#143c5b" Margin="0,5"/>
                <TextBox x:Name="txtPrecio" 
                         Height="40" Padding="10" 
                         FontSize="14" 
                         BorderBrush="#143c5b" BorderThickness="1"/>
            </StackPanel>
        </Grid>

        <!-- ESTANTE Y FILA EN GRID -->
        <Grid Grid.Row="8" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ESTANTE -->
            <StackPanel Grid.Column="0">
                <TextBlock Text="Estante:" 
                           FontSize="14" FontWeight="SemiBold" 
                           Foreground="#143c5b" Margin="0,5"/>
                <TextBox x:Name="txtEstante" 
                         Height="40" Padding="10" 
                         FontSize="14" 
                         BorderBrush="#143c5b" BorderThickness="1"/>
            </StackPanel>

            <!-- FILA -->
            <StackPanel Grid.Column="2">
                <TextBlock Text="Fila:" 
                           FontSize="14" FontWeight="SemiBold" 
                           Foreground="#143c5b" Margin="0,5"/>
                <TextBox x:Name="txtFila" 
                         Height="40" Padding="10" 
                         FontSize="14" 
                         BorderBrush="#143c5b" BorderThickness="1"/>
            </StackPanel>
        </Grid>

        <!-- URL DE IMAGEN -->
        <TextBlock Grid.Row="9" Text="URL de la Imagen:" 
                   FontSize="14" FontWeight="SemiBold" 
                   Foreground="#143c5b" Margin="0,5"/>
        <TextBox x:Name="txtImagenURL" Grid.Row="10" 
                 Height="40" Padding="10" 
                 FontSize="14" 
                 BorderBrush="#143c5b" BorderThickness="1"
                 Margin="0,0,0,10"/>

        <!-- BOTONES -->
        <Grid Grid.Row="11" Margin="0,20,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Botón Actualizar -->
            <Button Grid.Column="0" x:Name="btnActualizar" 
                    Content="ACTUALIZAR PRODUCTO" 
                    Height="45" 
                    Background="#143c5b" 
                    Foreground="White" 
                    FontWeight="Bold" 
                    FontSize="16"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="BtnActualizar_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border" Background="#143c5b" CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#1f5c8a"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- Botón Cancelar -->
            <Button Grid.Column="2" x:Name="btnCancelar" 
                    Content="CANCELAR" 
                    Height="45" 
                    Background="Gray" 
                    Foreground="White" 
                    FontWeight="Bold" 
                    FontSize="16"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="BtnCancelar_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border" Background="Gray" CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#666666"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>

        <!-- Mensaje de estado -->
        <TextBlock x:Name="txtEstado" Grid.Row="12" 
                   Text="" 
                   Foreground="Red" 
                   HorizontalAlignment="Center"
                   VerticalAlignment="Bottom"
                   Margin="0,10"/>
    </Grid>
</Window>